{
  "name": "grapplehook-ui",
  "version": "0.1.4",
  "description": "Desktop GUI for grapplehook: download and transcode videos (yt-dlp + ffmpeg + aria2c) with live progress and cancellation.",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-renderer.mjs",
    "start": "pnpm run build && electron .",
    "dev": "pnpm run build && electron . --dev",
    "typecheck": "tsc --noEmit",
    "dist": "pnpm run build && electron-builder",
    "format": "prettier . --write",
    "lint": "eslint --fix",
    "bonita": "pnpm run lint && pnpm run format"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "electron",
    "yt-dlp",
    "ffmpeg",
    "aria2c",
    "downloader",
    "grapplehook"
  ],
  "license": "MIT",
  "dependencies": {
    "grapplehook-core": "^0.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.6",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "build": {
    "appId": "dev.grapplehook.ui",
    "productName": "Grapplehook",
    "artifactName": "${name}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
